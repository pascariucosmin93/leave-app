{
  "id": null,
  "uid": "employee-leave-comprehensive",
  "title": "Leave – Comprehensive",
  "tags": ["employee-leave", "prometheus", "loki"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "editable": true,
  "gnetId": null,
  "templating": {"list": []},
  "annotations": {"list": []},
  "time": {"from": "now-24h", "to": "now"},
  "panels": [
    {"type": "row", "title": "Rezumat Leave", "id": 1, "collapsed": false, "gridPos": {"x": 0, "y": 0, "w": 24, "h": 1}},
    {"type": "stat", "title": "Pending (acum)", "id": 2, "gridPos": {"x": 0, "y": 1, "w": 6, "h": 4}, "datasource": {"type": "prometheus", "uid": "prometheus"}, "targets": [{"expr": "pending_leaves_total", "refId": "A"}]},
    {"type": "stat", "title": "Aprobate (interval)", "id": 3, "gridPos": {"x": 6, "y": 1, "w": 6, "h": 4}, "datasource": {"type": "prometheus", "uid": "prometheus"}, "targets": [{"expr": "sum(increase(leaves_approved_total[$__range]))", "refId": "A"}]},
    {"type": "stat", "title": "Respinse (interval)", "id": 4, "gridPos": {"x": 12, "y": 1, "w": 6, "h": 4}, "datasource": {"type": "prometheus", "uid": "prometheus"}, "targets": [{"expr": "sum(increase(leaves_rejected_total[$__range]))", "refId": "A"}]},
    {"type": "stat", "title": "Trimise (interval)", "id": 5, "gridPos": {"x": 18, "y": 1, "w": 6, "h": 4}, "datasource": {"type": "prometheus", "uid": "prometheus"}, "targets": [{"expr": "sum(increase(leaves_submitted_total[$__range]))", "refId": "A"}]},

    {"type": "row", "title": "Trafic HTTP (Prometheus)", "id": 6, "collapsed": false, "gridPos": {"x": 0, "y": 5, "w": 24, "h": 1}},
    {"type": "timeseries", "title": "Rată request-uri pe endpoint", "id": 7, "gridPos": {"x": 0, "y": 6, "w": 12, "h": 8}, "datasource": {"type": "prometheus", "uid": "prometheus"}, "targets": [{"expr": "sum by (endpoint) (rate(http_requests_total[5m]))", "legendFormat": "{{endpoint}}", "refId": "A"}], "fieldConfig": {"defaults": {"unit": "1/s"}}},
    {"type": "timeseries", "title": "Latență p90 per endpoint", "id": 8, "gridPos": {"x": 12, "y": 6, "w": 12, "h": 8}, "datasource": {"type": "prometheus", "uid": "prometheus"}, "targets": [{"expr": "histogram_quantile(0.9, sum by (le, endpoint) (rate(http_request_duration_seconds_bucket[5m])))", "legendFormat": "p90 {{endpoint}}", "refId": "A"}], "fieldConfig": {"defaults": {"unit": "s"}}},

    {"type": "row", "title": "Trafic / IP / Status (Loki)", "id": 9, "collapsed": false, "gridPos": {"x": 0, "y": 14, "w": 24, "h": 1}},
    {"type": "timeseries", "title": "Rată pe status (Loki)", "id": 10, "gridPos": {"x": 0, "y": 15, "w": 12, "h": 8}, "datasource": {"type": "loki", "uid": "loki"}, "targets": [{"refId": "A", "expr": "sum by (status) (rate(({app=\"employee-leave-backend\"}) | regexp \".*\\s(?P<status>[0-9]{3})\\s.*\" [5m]))"}], "fieldConfig": {"defaults": {"unit": "1/s"}}},
    {"type": "table", "title": "Top IP-uri (Loki)", "id": 11, "gridPos": {"x": 12, "y": 15, "w": 12, "h": 8}, "datasource": {"type": "loki", "uid": "loki"}, "targets": [{"refId": "A", "expr": "topk(20, sum by (ip) (rate(({app=\"employee-leave-backend\"}) | regexp \"(?P<ip>(?:[0-9]{1,3}\\.){3}[0-9]{1,3})\" [5m])))"}], "options": {"showHeader": true}},
    {"type": "stat", "title": "IP-uri unice (estimare)", "id": 12, "gridPos": {"x": 0, "y": 23, "w": 6, "h": 4}, "datasource": {"type": "loki", "uid": "loki"}, "targets": [{"refId": "A", "expr": "count(sum by (ip) (rate(({app=\"employee-leave-backend\"}) | regexp \"(?P<ip>(?:[0-9]{1,3}\\.){3}[0-9]{1,3})\" [5m])))"}]},
    {"type": "stat", "title": "Total request-uri (Loki)", "id": 13, "gridPos": {"x": 6, "y": 23, "w": 6, "h": 4}, "datasource": {"type": "loki", "uid": "loki"}, "targets": [{"refId": "A", "expr": "sum(rate(({app=\"employee-leave-backend\"}) [5m]))"}], "fieldConfig": {"defaults": {"unit": "1/s"}}},
    {"type": "table", "title": "Top Browsere (UA)", "id": 14, "gridPos": {"x": 12, "y": 23, "w": 12, "h": 8}, "datasource": {"type": "loki", "uid": "loki"}, "targets": [{"refId": "A", "expr": "topk(10, sum by (ua) (rate(({app=\"employee-leave-backend\"}) | regexp \".*\\\"(?P<ua>[^\\\"]+)\\\".*\" [5m])))"}]}
  ]
}
